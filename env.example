# Copy this file to .env and fill in your values

# Your OMDB API key — get free at https://www.omdbapi.com/apikey.aspx
OMDB_KEY=your_omdb_api_key_here

# Secret for signing JWT tokens — make this a long random string
JWT_SECRET=change_this_to_a_random_secret_string_at_least_32_chars

# Port (Railway sets this automatically, leave as is)
PORT=3000
